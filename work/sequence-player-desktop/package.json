{
  "name": "sequence-player-desktop",
  "version": "0.1.0",
  "description": "Sequence Player desktop packaging shell.",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "sync": "node scripts/sync-assets.mjs",
    "build:github": "npm run sync && electron-builder --config electron-builder.github.json",
    "build:itch": "npm run sync && electron-builder --config electron-builder.itch.json",
    "release:all": "npm run sync && npm run build:github && npm run build:itch && node scripts/copy-release.mjs",
    "release:all:system-ca": "set NODE_OPTIONS=--use-system-ca&& npm run release:all"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}
